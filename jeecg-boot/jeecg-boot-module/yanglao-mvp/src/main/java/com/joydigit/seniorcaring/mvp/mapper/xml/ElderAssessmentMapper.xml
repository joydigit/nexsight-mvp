<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joydigit.seniorcaring.mvp.mapper.ElderAssessmentMapper">

    <select id="pageList" resultType="com.joydigit.seniorcaring.mvp.entity.ElderAssessment">
        SELECT
            a.*
        FROM
            elder_assessment a
        WHERE
            a.del_flag = 0
        <if test="data.checkinId != null and data.checkinId != ''">
            and a.checkin_id like concat(concat('%',#{data.checkinId}),'%')
        </if>
        <if test="data.customerId != null and data.customerId != ''">
            and a.customer_id = #{data.customerId}
        </if>
        <if test="data.assessmentTypeCode != null and data.assessmentTypeCode != ''">
            and a.assessment_type_code = #{data.assessmentTypeCode}
        </if>
        ORDER BY a.create_time DESC
    </select>
</mapper>